pipeline {
    agent any

    environment {
        IMAGE_NAME    = "devops-quest-frontend"
        DOCKER_HUB    = credentials('dockerhub-credentials')   // Jenkins credential : username/password Docker Hub
        AZURE_VM_IP   = credentials('azure-frontend-ip')       // Jenkins secret text : IP publique de la VM
        SSH_KEY       = credentials('azure-ssh-key')           // Jenkins SSH key : clé privée pour la VM Azure
        VITE_API_URL  = "https://devopsquest.duckdns.org"      // Frontend appelle l'API via Caddy (HTTPS)
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ── 1. Récupération du code ─────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                sh 'echo "Commit : $(git rev-parse --short HEAD)"'
            }
        }

        // ── 2. Installation des dépendances ────────────────────────────────
        stage('Install') {
            steps {
                dir('devops-quest-frontend') {
                    sh 'corepack enable && corepack prepare pnpm@9 --activate'
                    sh 'pnpm install --frozen-lockfile'
                }
            }
        }

        // ── 3. Tests ────────────────────────────────────────────────────────
        stage('Test') {
            steps {
                dir('devops-quest-frontend') {
                    sh 'pnpm test'
                }
            }
            post {
                failure {
                    echo 'Les tests frontend ont échoué — arrêt du pipeline.'
                }
            }
        }

        // ── 4. Build & Deploy directement sur la VM Azure ─────────────────
        stage('Build & Deploy on Azure VM') {
            steps {
                sshagent(credentials: ['azure-ssh-key']) {
                    sh '''
                        rsync -az --delete \
                            --exclude=node_modules \
                            --exclude=.env \
                            --exclude=dist \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            devops-quest-frontend/ \
                            "azureuser@${AZURE_VM_IP}:~/devops-quest-frontend/"

                        ssh -o StrictHostKeyChecking=no "azureuser@${AZURE_VM_IP}" bash <<EOF
set -e
cd ~/devops-quest-frontend
docker build --build-arg "VITE_API_URL=${VITE_API_URL}" -t devops-quest-frontend:latest .
docker stop devops-quest-frontend 2>/dev/null || true
docker rm   devops-quest-frontend 2>/dev/null || true
docker run -d \\
    --name devops-quest-frontend \\
    --restart unless-stopped \\
    -p 8080:80 \\
    devops-quest-frontend:latest
EOF
                    '''
                }
            }
        }

        // ── 5. Vérification du déploiement (via Caddy/HTTPS) ────────────────
        stage('Health Check') {
            steps {
                sh '''
                    sleep 5
                    curl -sf https://devopsquest.duckdns.org/ | grep -q "DevOps Quest" \
                        && echo "Frontend OK" \
                        || { echo "Health check échoué"; exit 1; }
                '''
            }
        }
    }

    post {
        success {
            echo "Déploiement frontend réussi → https://devopsquest.duckdns.org"
        }
        failure {
            echo 'Pipeline échoué. Vérifie les logs ci-dessus.'
        }
    }
}
