pipeline {
    agent any

    environment {
        IMAGE_NAME   = "devops-quest-api"
        DOCKER_HUB   = credentials('dockerhub-credentials')  // Jenkins credential : username/password Docker Hub
        AZURE_VM_IP  = credentials('azure-api-ip')           // Jenkins secret text : IP publique de la VM backend
        SSH_KEY      = credentials('azure-ssh-key')          // Jenkins SSH key : clé privée pour la VM Azure
        JWT_SECRET   = credentials('jwt-secret')             // Jenkins secret text : JWT_SECRET de production
        FRONTEND_URL = credentials('frontend-url')           // Jenkins secret text : URL publique du frontend
        SMTP_USER    = credentials('smtp-user')              // Jenkins secret text : adresse email SMTP
        SMTP_PASS    = credentials('smtp-pass')              // Jenkins secret text : mot de passe application Gmail
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ── 1. Récupération du code ─────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                sh 'echo "Commit : $(git rev-parse --short HEAD)"'
            }
        }

        // ── 2. Installation des dépendances ────────────────────────────────
        stage('Install') {
            steps {
                dir('devops-quest-api') {
                    sh 'corepack enable && corepack prepare pnpm@9 --activate'
                    sh 'pnpm install --frozen-lockfile'
                }
            }
        }

        // ── 3. Tests ────────────────────────────────────────────────────────
        stage('Test') {
            steps {
                dir('devops-quest-api') {
                    // DB en mémoire pour les tests (défini dans tests/setup.js)
                    sh 'pnpm test'
                }
            }
            post {
                failure {
                    echo 'Les tests API ont échoué — arrêt du pipeline.'
                }
            }
        }

        // ── 4. Build & Deploy directement sur la VM Azure (x64 natif) ────────
        stage('Build & Deploy on Azure VM') {
            steps {
                sshagent(credentials: ['azure-ssh-key']) {
                    sh '''
                        rsync -az --delete \
                            --exclude=node_modules \
                            --exclude=.env \
                            --exclude=*.db --exclude=*.db-shm --exclude=*.db-wal \
                            -e "ssh -o StrictHostKeyChecking=no" \
                            devops-quest-api/ \
                            "azureuser@${AZURE_VM_IP}:~/devops-quest-api/"

                        ssh -o StrictHostKeyChecking=no "azureuser@${AZURE_VM_IP}" bash <<EOF
set -e
cd ~/devops-quest-api
docker build -t devops-quest-api:latest .
docker stop devops-quest-api 2>/dev/null || true
docker rm   devops-quest-api 2>/dev/null || true
docker run -d \\
    --name devops-quest-api \\
    --restart unless-stopped \\
    -p 3001:3001 \\
    -e PORT=3001 \\
    -e "JWT_SECRET=${JWT_SECRET}" \\
    -e "FRONTEND_URL=${FRONTEND_URL}" \\
    -e DB_PATH=/data/devops-quest.db \\
    -e SMTP_HOST=smtp.gmail.com \\
    -e SMTP_PORT=587 \\
    -e "SMTP_USER=${SMTP_USER}" \\
    -e "SMTP_PASS=${SMTP_PASS}" \\
    -e "SMTP_FROM=DevOps Quest <${SMTP_USER}>" \\
    -v devops-quest-data:/data \\
    devops-quest-api:latest
EOF
                    '''
                }
            }
        }

        // ── 5. Vérification du déploiement (via Caddy/HTTPS) ────────────────
        stage('Health Check') {
            steps {
                sh '''
                    sleep 5
                    curl -sf https://devopsquest.duckdns.org/api/health | grep -q '"status":"ok"' \
                        && echo "API OK" \
                        || { echo "Health check échoué"; exit 1; }
                '''
            }
        }
    }

    post {
        success {
            echo "Déploiement API réussi → https://devopsquest.duckdns.org/api"
        }
        failure {
            echo 'Pipeline échoué. Vérifie les logs ci-dessus.'
        }
    }
}
